AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7
AIRFLOW_PROJ_DIR=.

_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=airflow_user
MONGO_PASSWORD=password
MONGO_DB=airflow_db
AIRFLOW_CONN_MONGO_DEFAULT='{"conn_type": "mongo", "host": "mongodb", "port": 27017, "login": "airflow_user", "password": "your_password_here"}'
MONGO_COLLECTION=processed_data

DATA_INPUT_PATH=/opt/airflow/data/input
DATA_OUTPUT_PATH=/opt/airflow/data/processed

_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-mongo
