AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7
AIRFLOW_PROJ_DIR=.

_AIRFLOW_WWW_USER_USERNAME=your_username
_AIRFLOW_WWW_USER_PASSWORD=your_password

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
AIRFLOW_CONN_MONGO_DEFAULT='{"conn_type": "mongo", "host": "mongodb", "port": 27017, "login": "your_mongo_user", "password": "your_mongo_password"}'

DATA_INPUT_PATH=/opt/airflow/data/input
DATA_OUTPUT_PATH=/opt/airflow/data/processed

_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-mongo

# Airflow Variables (paths and config) — доступны как Variable.get("data_base_path") и т.д.
AIRFLOW_VAR_DATA_BASE_PATH=/opt/airflow/data
AIRFLOW_VAR_INPUT_FILE_NAME=tiktok_google_play_reviews.csv
AIRFLOW_VAR_PROCESSED_FILE_NAME=processed_data.csv
AIRFLOW_VAR_MONGO_CONN_ID=mongo_default
AIRFLOW_VAR_MONGO_COLLECTION=processed_data
AIRFLOW_VAR_MONGO_DB=airflow_db
